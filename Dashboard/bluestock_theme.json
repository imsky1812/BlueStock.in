{
  "name": "Bluestock Corporate Theme",
  "dataColors": [
    "#0f172a",
    "#2563eb",
    "#0d9488",
    "#ea580c",
    "#e11d48",
    "#4f46e5",
    "#0891b2",
    "#10b981"
  ],
  "background": "#ffffff",
  "foreground": "#0f172a",
  "tableAccent": "#2563eb",
  "visualStyles": {
    "*": {
      "*": {
        "background": [
          {
            "show": true,
            "color": { "solid": { "color": "#ffffff" } },
            "transparency": 0
          }
        ],
        "border": [
          {
            "show": true,
            "color": { "solid": { "color": "#e2e8f0" } },
            "radius": 8
          }
        ],
        "title": [
          {
            "show": true,
            "fontColor": { "solid": { "color": "#0f172a" } },
            "fontSize": 12,
            "fontFamily": "Segoe UI",
            "bold": true
          }
        ],
        "dropShadow": [
          {
            "show": true,
            "color": { "solid": { "color": "#000000" } },
            "transparency": 95,
            "preset": "Custom",
            "angle": 135,
            "distance": 4,
            "blur": 8
          }
        ]
      }
    },
    "card": {
      "*": {
        "labels": [
          {
            "fontSize": 24,
            "color": { "solid": { "color": "#2563eb" } },
            "fontFamily": "Segoe UI",
            "bold": true
          }
        ],
        "categoryLabels": [
          {
            "fontSize": 9,
            "color": { "solid": { "color": "#64748b" } },
            "fontFamily": "Segoe UI"
          }
        ]
      }
    }
  }
}
